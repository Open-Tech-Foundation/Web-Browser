{
  "name": "otf-browser",
  "version": "0.1.0-alpha.56",
  "type": "module",
  "description": "Privacy browser on Chromium's content layer with a Rust backend",
  "scripts": {
    "dev": "fuser -k 3000/tcp || true; (cd ui && bun x vite --port 3000 --strictPort &) && bun x wait-on http://localhost:3000 && bun run dev:browser; fuser -k 3000/tcp || true",
    "dev:browser": "OTF_DEV_MODE=1 ../chromium/src/out/otf/otf_browser --no-sandbox http://localhost:3000/",
    "build": "bun run build:ui && bun run build:engine",
    "build:ui": "bun x vite build ui",
    "build:engine": "engine/scripts/build-engine.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test:engine": "cd engine/backend && cargo test",
    "test:js": "bun test ui/src/shared/search.test.js",
    "test:e2e": "bun scripts/run-e2e-suite.js",
    "test:e2e:split-view": "scripts/run-e2e.sh tests/e2e/split-view.test.js",
    "test:e2e:file": "scripts/run-e2e.sh",
    "test": "bun run test:engine && bun run test:js",
    "setup": "engine/scripts/bootstrap-chromium.sh",
    "release": "bun scripts/release.js"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "marked": "^18.0.4",
    "monaco-editor": "^0.55.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  }
}
